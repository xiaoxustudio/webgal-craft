    "@vueuse/rxjs": "^14.2.1",
    "alfaaz": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "dayjs": "^1.11.20",
    "dexie": "^4.4.2",
    "lru-cache": "^11.2.7",
    "mime": "^4.1.0",
    "monaco-editor": "~0.51.0",
    "natural-compare-lite": "^1.4.0",
    "notivue": "^2.4.5",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.9.3",
    "sanitize-filename": "^1.6.4",

{
  "name": "webgal-craft",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite dev",
    "build": "tauri build",
    "build:web": "bun typecheck:app && bun typecheck:node && vite build",
    "preview:web": "vite preview",
    "tauri": "tauri",
    "typecheck": "bun typecheck:app && bun typecheck:node && bun typecheck:test",
    "typecheck:app": "vue-tsc -p tsconfig.app.json",
    "typecheck:node": "vue-tsc -p tsconfig.node.json",
    "typecheck:test": "vue-tsc -p tsconfig.test.json",
    "test": "bun test:unit && bun test:browser && bun test:integration",
    "test:rust": "cargo test --locked --manifest-path src-tauri/Cargo.toml",
    "test:coverage": "vitest run --project unit --coverage",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:integration": "playwright test --config integration/playwright.config.ts",
    "test:unit:watch": "vitest --project unit",
    "lint": "bun lint:js && bun lint:style && bun lint:i18n",
    "lint:fix": "bun lint:js:fix && bun lint:style:fix && bun lint:i18n:fix",
    "lint:js": "eslint '**/*.{js,jsx,ts,tsx,cjs,mjs,vue}'",
    "lint:js:fix": "eslint '**/*.{js,jsx,ts,tsx,cjs,mjs,vue}' --fix",
    "lint:style": "stylelint 'src/**/*.{css,vue}'",
    "lint:style:fix": "stylelint 'src/**/*.{css,vue}' --fix",
    "lint:i18n": "eslint 'src/locales/*.{json,json5,yaml,yml}'",
    "lint:i18n:fix": "eslint 'src/locales/*.{json,json5,yaml,yml}' --fix",
    "lint:rs": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "lint:rs:fix": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features --fix --allow-dirty --allow-staged",
    "format:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --all"
  },
  "dependencies": {
    "@andypf/json-viewer": "^2.3.2",

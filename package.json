    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "^11.3.0",
    "vue-inline-svg": "^4.0.1",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
    "wavesurfer.js": "^7.12.5",
